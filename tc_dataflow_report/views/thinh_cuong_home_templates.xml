<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="thinh_cuong_dashboard_layout" name="TC Dashboard Layout">
        <html lang="vi">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title><t t-esc="page_title"/></title>
                <link rel="icon" type="image/png" href="/tc_dataflow_report/static/src/img/thinhcuong_logo_mark.png"/>
                <link rel="stylesheet" type="text/css" href="/tc_dataflow_report/static/src/css/import_data.css"/>
                <script type="text/javascript" src="/tc_dataflow_report/static/src/js/daily_tabs.js" defer="defer"/>
                <script type="text/javascript" src="/tc_dataflow_report/static/src/js/daily_upload.js" defer="defer"/>
                <script type="text/javascript" src="/tc_dataflow_report/static/src/js/dashboard_user_menu.js" defer="defer"/>
            </head>
            <body class="tc-dashboard-body">
                <div class="tc-dashboard-page">
                    <div class="tc-dashboard-shell">
                        <aside class="tc-dashboard-sidebar">
                            <div class="tc-dashboard-brand">
                                <h1><t t-esc="brand_name"/></h1>
                                <button class="tc-dashboard-brand__alert" type="button" aria-label="Thông báo">
                                    <span class="material-symbols-outlined">notifications</span>
                                </button>
                            </div>

                            <nav class="tc-dashboard-nav">
                                <a t-foreach="nav_items"
                                   t-as="item"
                                   t-att-href="item['href']"
                                   t-attf-class="tc-dashboard-nav__link {{ 'is-active' if item['active'] else '' }}">
                                    <span class="material-symbols-outlined"><t t-esc="item['icon']"/></span>
                                    <span><t t-esc="item['label']"/></span>
                                </a>
                            </nav>

                            <section t-if="show_sidebar_time_filter" class="tc-dashboard-sidebar__section">
                                <p class="tc-dashboard-sidebar__label">Thời gian</p>
                                <div class="tc-dashboard-date-card">
                                    <t t-if="sidebar_period_value">
                                        <button type="button" class="tc-dashboard-period-trigger">
                                            <span class="material-symbols-outlined">calendar_today</span>
                                            <span><t t-esc="sidebar_period_value"/></span>
                                            <span class="material-symbols-outlined">expand_more</span>
                                        </button>
                                    </t>
                                    <t t-else="">
                                        <input class="tc-dashboard-date-input"
                                               type="date"
                                               data-upload-filter-date="1"
                                               t-att-value="selected_date_input"/>
                                    </t>
                                </div>
                            </section>

                            <section t-if="show_sidebar_recent_days" class="tc-dashboard-sidebar__section">
                                <p class="tc-dashboard-sidebar__label">Thời gian gần đây</p>
                                <div class="tc-dashboard-timeline" data-recent-days="1">
                                    <article t-foreach="recent_days"
                                             t-as="day"
                                             t-attf-class="tc-dashboard-timeline__item {{ day['status_class'] }}">
                                        <div class="tc-dashboard-timeline__row">
                                            <strong><t t-esc="day['date']"/></strong>
                                            <span><t t-esc="day['status']"/></span>
                                        </div>
                                        <p><t t-esc="day['note']"/></p>
                                    </article>
                                </div>
                            </section>
                        </aside>

                        <div class="tc-dashboard-stage">
                            <header class="tc-dashboard-topbar">
                                <div class="tc-dashboard-user-menu" data-user-menu="1">
                                    <button type="button"
                                            class="tc-dashboard-user"
                                            data-user-menu-trigger="1"
                                            aria-haspopup="menu"
                                            aria-expanded="false">
                                        <div class="tc-dashboard-user__meta">
                                            <strong><t t-esc="user_name"/></strong>
                                            <span><t t-esc="user_role"/></span>
                                        </div>
                                        <div class="tc-dashboard-user__avatar">
                                            <t t-esc="user_initials"/>
                                        </div>
                                        <span class="material-symbols-outlined tc-dashboard-user__chevron">expand_more</span>
                                    </button>

                                    <div class="tc-dashboard-user-dropdown"
                                         data-user-menu-panel="1"
                                         role="menu"
                                         aria-label="Tài khoản người dùng"
                                         hidden="hidden">
                                        <a class="tc-dashboard-user-dropdown__item"
                                           href="https://www.odoo.com/help"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           role="menuitem">
                                            <span>Help</span>
                                        </a>
<!--                                        <div class="tc-dashboard-user-dropdown__item is-static" role="presentation">-->
<!--                                            <span>Shortcuts</span>-->
<!--                                            <span class="tc-dashboard-user-dropdown__shortcut">CTRL+K</span>-->
<!--                                        </div>-->
                                        <div class="tc-dashboard-user-dropdown__separator" role="separator"></div>
                                        <div class="tc-dashboard-user-dropdown__item is-static" role="presentation">
                                            <span class="tc-dashboard-user-dropdown__status">
                                                <span class="tc-dashboard-user-dropdown__status-dot" data-user-menu-status-dot="1"></span>
                                                <span data-user-menu-status-label="1">Online</span>
                                            </span>
<!--                                            <span class="material-symbols-outlined tc-dashboard-user-dropdown__arrow">chevron_right</span>-->
                                        </div>
<!--                                        <a class="tc-dashboard-user-dropdown__item"-->
<!--                                           href="/odoo/action-base.action_res_users_my"-->
<!--                                           role="menuitem">-->
<!--                                            <span>My Preferences</span>-->
<!--                                        </a>-->
<!--                                        <button type="button"-->
<!--                                                class="tc-dashboard-user-dropdown__item"-->
<!--                                                data-user-menu-account="1"-->
<!--                                                role="menuitem">-->
<!--                                            <span>My Odoo.com Account</span>-->
<!--                                        </button>-->
                                        <a class="tc-dashboard-user-dropdown__item"
                                           href="/web/session/logout?redirect=%2Fweb%2Flogin%3Fredirect%3D%2Fhome"
                                           role="menuitem">
                                            <span>Log out</span>
                                        </a>
                                    </div>
                                </div>
                            </header>

                            <main class="tc-dashboard-main">
                                <t t-out="0"/>
                            </main>
                        </div>
                    </div>
                </div>
            </body>
        </html>
    </template>

    <template id="thinh_cuong_home_report" name="TC Financial Report Home">
        <t t-call="tc_dataflow_report.thinh_cuong_dashboard_layout">
            <section class="tc-dashboard-header">
                <div class="tc-dashboard-header__copy">
                    <h2><t t-esc="report_title"/></h2>
                    <p t-if="report_subtitle" class="tc-dashboard-header__subtitle"><t t-esc="report_subtitle"/></p>
                    <div class="tc-dashboard-header__date">
                        <span>Ngày thực hiện:</span>
                        <button type="button" class="tc-dashboard-date-chip">
                            <span class="material-symbols-outlined">calendar_today</span>
                            <span data-selected-date-display="1"><t t-esc="selected_date_display"/></span>
                        </button>
                    </div>
                </div>
                <div t-if="dashboard_header_actions" class="tc-dashboard-header__actions">
                    <div class="tc-dashboard-header__action-row">
                        <a t-foreach="dashboard_header_actions"
                           t-as="action"
                           t-att-href="action['href']"
                           t-att-class="action.get('button_class') or 'tc-temporary-button tc-temporary-button--ghost'">
                            <t t-esc="action['label']"/>
                        </a>
                    </div>
                </div>
            </section>

            <section class="tc-dashboard-tabs" data-daily-tabs="1" role="tablist" aria-label="Daily report tabs">
                <button t-foreach="tabs"
                        t-as="tab"
                        type="button"
                        role="tab"
                        t-att-data-tab-key="tab['key']"
                        t-att-aria-controls="'tc-daily-panel-' + tab['key']"
                        t-att-aria-selected="'true' if tab['active'] else 'false'"
                        t-attf-class="tc-dashboard-tabs__item {{ 'is-active' if tab['active'] else '' }}">
                    <t t-esc="tab['label']"/>
                </button>
            </section>

            <div class="tc-daily-sections"
                 data-daily-sections="1"
                 t-att-data-daily-workspace="daily_workspace or 'daily'">
                <section t-foreach="daily_sections"
                         t-as="section"
                         role="tabpanel"
                         t-att-id="'tc-daily-panel-' + section['key']"
                         t-att-data-section-key="section['key']"
                          t-att-data-checking-count="section['checking_count']"
                          t-att-data-section-label="section['short_label']"
                         t-att-data-hide-upload-zone="'1' if section['hide_upload_zone'] else '0'"
                         t-att-data-current-file-id="section['current_file_id']"
                         t-att-aria-hidden="'false' if section['active'] else 'true'"
                         t-att-hidden="None if section['active'] else 'hidden'"
                         t-attf-class="tc-daily-section {{ 'is-active' if section['active'] else '' }}">
                    <section class="tc-dashboard-panel">
                        <h3 class="tc-dashboard-panel__title"><t t-esc="section['uploaded_files_title']"/></h3>
                        <div class="tc-dashboard-table-wrap">
                            <table class="tc-dashboard-table">
                                <thead>
                                    <tr>
                                        <th>File</th>
                                        <th>Version</th>
                                        <th>Ngày tải lên</th>
                                        <th>Dung lượng</th>
                                        <th>Status</th>
                                        <th class="is-right">Action</th>
                                    </tr>
                                </thead>
                                <tbody data-uploaded-files-body="1">
                                    <t t-if="section['uploaded_files']">
                                        <tr t-foreach="section['uploaded_files']" t-as="file">
                                            <td class="is-strong"><t t-esc="file['name']"/></td>
                                            <td><t t-esc="file['version']"/></td>
                                            <td><t t-esc="file['uploaded_at_display']"/></td>
                                            <td><t t-esc="file['size_display']"/></td>
                                            <td>
                                                <span t-attf-class="tc-dashboard-status {{ file['status_class'] }}">
                                                    <span class="material-symbols-outlined"><t t-esc="file['status_icon']"/></span>
                                                    <t t-esc="file['status']"/>
                                                </span>
                                            </td>
                                            <td class="is-right">
                                                <div class="tc-dashboard-table__actions">
                                                    <button t-foreach="file['actions']"
                                                            t-as="action"
                                                            type="button"
                                                            t-attf-class="tc-dashboard-table__action is-{{ action.get('style') or 'ghost' }}"
                                                            t-att-data-action-key="action.get('key')"
                                                            t-att-data-file-id="file.get('id')"
                                                            t-att-disabled="'disabled' if action.get('disabled') else None">
                                                        <span class="material-symbols-outlined"><t t-esc="action.get('icon') or 'visibility'"/></span>
                                                        <t t-esc="action['label']"/>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr class="tc-dashboard-table__empty">
                                            <td colspan="6">Chưa có file nào được tải lên.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section class="tc-dashboard-dropzone"
                             data-upload-zone="1"
                             tabindex="0"
                             t-att-hidden="'hidden' if section['hide_upload_zone'] else None">
                        <input class="tc-dashboard-upload-input"
                               type="file"
                               accept=".xlsx,.xlsm"
                               data-upload-input="1"/>
                        <div class="tc-dashboard-dropzone__icon">
                            <span class="material-symbols-outlined">cloud_upload</span>
                        </div>
                        <strong>Kéo thả file Excel vào đây hoặc <span>chọn file từ máy</span></strong>
                        <p>Hỗ trợ .xlsx, .xlsm</p>
                        <button type="button" class="tc-dashboard-dropzone__button" data-upload-trigger="1"></button>
                        <p class="tc-dashboard-upload-feedback" data-upload-feedback="1" hidden="hidden"></p>
                    </section>

                    <section class="tc-dashboard-panel">
                        <h3 class="tc-dashboard-panel__title"><t t-esc="section['preview_title']"/></h3>
                        <div class="tc-dashboard-table-wrap">
                            <table class="tc-dashboard-table tc-dashboard-table--preview"
                                   data-preview-table="1"
                                   t-att-hidden="None if section['preview_columns'] else 'hidden'">
                                <thead>
                                    <tr data-preview-head="1">
                                        <th t-foreach="section['preview_columns']"
                                            t-as="column"
                                            t-att-class="column.get('header_class')">
                                            <t t-esc="column['label']"/>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody data-preview-body="1">
                                    <t t-if="section['preview_rows']">
                                        <tr t-foreach="section['preview_rows']" t-as="row">
                                            <td t-foreach="section['preview_columns']"
                                                t-as="column"
                                                t-att-class="column.get('cell_class')">
                                                <t t-esc="row[column['field']]"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-elif="section['preview_columns']">
                                        <tr class="tc-dashboard-table__empty">
                                            <td t-att-colspan="len(section['preview_columns']) or 1">File đã được đọc nhưng chưa có dòng dữ liệu để hiển thị.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            <div class="tc-dashboard-empty"
                                 data-preview-empty="1"
                                 t-att-hidden="'hidden' if section['preview_columns'] else None">
                                Chưa có dữ liệu preview. Hãy tải lên file Excel đúng mẫu để xem trước.
                            </div>
                            <div class="tc-dashboard-preview-pagination"
                                 data-preview-pagination="1"
                                 t-att-data-preview-page="section['preview_pagination']['page']"
                                 t-att-data-preview-total-pages="section['preview_pagination']['total_pages']"
                                 t-att-data-preview-has-prev="'1' if section['preview_pagination']['has_prev'] else '0'"
                                 t-att-data-preview-has-next="'1' if section['preview_pagination']['has_next'] else '0'"
                                 t-att-hidden="'hidden' if not section['preview_columns'] else None">
                                <p class="tc-dashboard-preview-pagination__summary" data-preview-summary="1">
                                    <t t-esc="section['preview_pagination']['summary']"/>
                                </p>
                                <div class="tc-dashboard-preview-pagination__controls">
                                    <button type="button"
                                            class="tc-dashboard-preview-pagination__button"
                                            data-preview-page-action="prev"
                                            t-att-disabled="'disabled' if not section['preview_pagination']['has_prev'] else None">
                                        <span class="material-symbols-outlined">chevron_left</span>
                                        Trước
                                    </button>
                                    <span class="tc-dashboard-preview-pagination__label" data-preview-page-label="1">
                                        Trang <t t-esc="section['preview_pagination']['page']"/> / <t t-esc="section['preview_pagination']['total_pages']"/>
                                    </span>
                                    <button type="button"
                                            class="tc-dashboard-preview-pagination__button"
                                            data-preview-page-action="next"
                                            t-att-disabled="'disabled' if not section['preview_pagination']['has_next'] else None">
                                        Sau
                                        <span class="material-symbols-outlined">chevron_right</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>
                </section>
            </div>

            <section class="tc-dashboard-notes">
                <h3>Ghi chú:</h3>
                <div class="tc-dashboard-notes__list">
                    <div t-foreach="notes" t-as="note" class="tc-dashboard-notes__item">
                        <strong><t t-esc="note['label']"/></strong>
                        <a href="#"><t t-esc="note['link_text']"/></a>
                    </div>
                </div>
            </section>
        </t>
    </template>
</odoo>
