<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_dimension_tree" model="ir.ui.view">
        <field name="name">account.dimension.tree</field>
        <field name="model">account.dimension</field>
        <field name="arch" type="xml">
            <list string="Chiều phân tích">
                <field name="code"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company" />
            </list>
        </field>
    </record>

    <record id="view_account_dimension_form" model="ir.ui.view">
        <field name="name">account.dimension.form</field>
        <field name="model">account.dimension</field>
        <field name="arch" type="xml">
            <form string="Chiều phân tích">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="code" />
                        <field name="company_id" groups="base.group_multi_company" />
                        <field name="company_id" invisible="1" />
                    </group>

                    <notebook>
                        <page name="Giá trị">
                            <field name="value_ids">
                                <list editable="bottom">
                                    <field name="id" optional="hide" />
                                    <field name="code" optional="hide" />
                                    <field name="name" />
                                </list>
                            </field>
                        </page>
                        <page name="Tài khoản KT áp dụng">
                            <field name="account_ids" domain="[('company_ids', 'parent_of', company_id)]">
                                <list editable="bottom">
                                    <field name="display_name" string="Tài khoản" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_dimension_search" model="ir.ui.view">
        <field name="name">account.dimension.search</field>
        <field name="model">account.dimension</field>
        <field name="arch" type="xml">
            <search string="Chiều phân tích">
                <field name="code"/>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_account_dimension" model="ir.actions.act_window">
        <field name="name">Chiều phân tích</field>
        <field name="res_model">account.dimension</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_account_dimension_search"/>
    </record>
</odoo>
