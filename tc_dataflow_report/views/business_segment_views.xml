<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_business_segment_tree" model="ir.ui.view">
        <field name="name">business.segment.tree</field>
        <field name="model">business.segment</field>
        <field name="arch" type="xml">
            <list string="Mảng kinh doanh">
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_business_segment_form" model="ir.ui.view">
        <field name="name">business.segment.form</field>
        <field name="model">business.segment</field>
        <field name="arch" type="xml">
            <form string="Mảng kinh doanh">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_business_segment_search" model="ir.ui.view">
        <field name="name">business.segment.search</field>
        <field name="model">business.segment</field>
        <field name="arch" type="xml">
            <search string="Mảng kinh doanh">
                <field name="code"/>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_business_segment" model="ir.actions.act_window">
        <field name="name">Mảng kinh doanh</field>
        <field name="res_model">business.segment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_business_segment_search"/>
    </record>

    <menuitem id="menu_business_segment"
              name="Mảng kinh doanh"
              parent="menu_tc_dataflow_config"
              action="action_business_segment"
              sequence="20"/>
</odoo>
