<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="tc_login_layout" inherit_id="web.login_layout" name="TC Login Layout" priority="30">
        <xpath expr="//t[@t-call='website.layout']" position="inside">
            <t t-set="title" t-value="'Đăng nhập | THINHCUONG GROUP'"/>
            <t t-set="head">
                <t t-out="head or ''"/>
                <link rel="stylesheet" type="text/css" href="/tc_dataflow_report/static/src/css/login.css"/>
            </t>
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
        </xpath>
        <xpath expr="//div[hasclass('oe_website_login_container')]" position="replace">
            <div class="tc-login-shell">
                <div class="tc-login-splash" aria-hidden="true">
                    <div class="tc-login-splash__inner">
                        <div class="tc-login-splash__badge">
                            <img class="tc-login-splash__logo" src="/tc_dataflow_report/static/src/img/thinhcuong_logo_mark.png" alt="" loading="eager"/>
                        </div>
                        <div class="tc-login-splash__copy">
                            <span>Thịnh Cường</span>
                            <span>GROUP</span>
                        </div>
                    </div>
                </div>
                <div class="tc-login-main">
                    <section class="tc-login-hero" aria-hidden="true">
                        <img class="tc-login-hero__art" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBKmecdkSaJvZzFZS6xa40v6fKc3FlYxhdQ0Dl4qXGGVHh-sxIGVTeW8258bFcl7GIlGPRTeTNFEgMJDaZoSI-7KBJ4M_rvTnB0adue8xSpfuYLBiG3Sk2DI8L2czXZEBMv1kpKPNZK-t-s1JiQQs-vRvrNFXsTRjjg4M2wTcW-wmQFy07DcKj7A8fMkDkpvadFskdefblwwywGBwzpkB4FJqC6Tlxc47aT_Kw-6xxstCcRzpv1jSxNi23K-KEuCYWlDQmX_9hIsgk" alt=""/>
                        <div class="tc-login-hero__wash"/>
                        <div class="tc-login-hero__content">
                            <div class="tc-login-brand">
                                <img class="tc-login-brand__logo" src="/tc_dataflow_report/static/src/img/thinhcuong_logo_mark.png" alt="" loading="eager"/>
                                <h1>THINHCUONG GROUP</h1>
                            </div>
                            <div class="tc-login-hero__headline">
                                <h2>Báo cáo 6 chỉ tiêu tài chính</h2>
                                <p>Giải pháp kế toán chuyên sâu dành cho các doanh nghiệp đòi hỏi sự chính xác tuyệt đối và hiệu suất vận hành tối ưu.</p>
                            </div>
                            <div class="tc-login-hero__stats">
                                <div class="tc-login-stat">
                                    <span class="tc-login-stat__icon tc-login-icon tc-login-icon--shield" role="presentation"/>
                                    <strong>Bảo mật đa lớp</strong>
                                    <p>Tiêu chuẩn ngân hàng quốc tế</p>
                                </div>
                                <div class="tc-login-stat">
                                    <span class="tc-login-stat__icon tc-login-icon tc-login-icon--chart" role="presentation"/>
                                    <strong>Báo cáo thông minh</strong>
                                    <p>Phân tích dữ liệu thời gian thực</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="tc-login-panel">
                        <div class="tc-login-panel__inner">
                            <div class="tc-login-mobile-brand">
                                <img class="tc-login-brand__logo tc-login-brand__logo--mobile" src="/tc_dataflow_report/static/src/img/thinhcuong_logo_mark.png" alt="" loading="eager"/>
                                <strong>THINHCUONG GROUP</strong>
                            </div>

                            <div class="tc-login-slot">
                                <t t-out="0"/>
                            </div>

                            <div class="tc-login-panel__meta">
<!--                                <p class="tc-login-panel__version">PHIÊN BẢN ENTERPRISE 2024.1.0</p>-->
                                <div class="tc-login-panel__links">
                                    <a href="#">Hỗ trợ kỹ thuật</a>
                                    <a href="#">Điều khoản</a>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </xpath>
    </template>

    <template id="tc_login" inherit_id="web.login" name="TC Login">
        <xpath expr="//div[@id='oe_structure_login_top']" position="replace">
            <div class="oe_structure" id="oe_structure_login_top"/>
            <div class="tc-login-intro">
                <h3>Chào mừng trở lại</h3>
                <p>Vui lòng nhập thông tin để truy cập hệ thống của bạn.</p>
            </div>
        </xpath>

        <xpath expr="//form[@data-captcha='login']" position="replace">
            <form t-attf-class="oe_login_form tc-login-form #{'' if login else 'd-none'}"
                  role="form"
                  t-attf-action="/web/login"
                  method="post"
                  onsubmit="this.action = '/web/login' + location.hash"
                  data-captcha="login">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <t t-set="has_auth_signup" t-value="bool(request.env['ir.module.module'].sudo().search_count([('name', '=', 'auth_signup'), ('state', '=', 'installed')]))"/>

                <div class="tc-login-db" t-if="databases and len(databases) &gt; 1">
                    <label for="db" class="form-label tc-login-label">Cơ sở dữ liệu</label>
                    <div class="tc-login-db__group">
                        <input type="text" name="db" t-att-value="request.db" id="db" class="form-control tc-login-input" required="required" readonly="readonly"/>
                        <a role="button" href="/web/database/selector" class="btn tc-login-db__button">Chọn</a>
                    </div>
                </div>

                <div class="tc-login-field field-login">
                    <label for="login" class="form-label tc-login-label">Tên đăng nhập / Email</label>
                    <div class="tc-login-control">
                        <span class="tc-login-control__icon tc-login-icon tc-login-icon--user" role="presentation"/>
                        <input type="text"
                               placeholder="user@company.com"
                               name="login"
                               t-att-value="login"
                               id="login"
                               class="form-control tc-login-input"
                               required="required"
                               autocapitalize="off"
                               autocomplete="username"/>
                    </div>
                </div>

                <div class="tc-login-field tc-login-field--password o_caps_lock_warning">
                    <label for="password" class="form-label tc-login-label tc-login-label--split">Mật khẩu</label>
                    <div class="tc-login-control tc-login-control--password">
                        <span class="tc-login-control__icon tc-login-icon tc-login-icon--lock" role="presentation"/>
                        <input type="password"
                               placeholder="••••••••"
                               name="password"
                               id="password"
                               class="form-control tc-login-input"
                               required="required"
                               autocomplete="current-password"
                               t-att-autofocus="'autofocus' if login else None"
                               maxlength="4096"/>
                        <button type="button" class="btn o_show_password tc-login-control__toggle" aria-label="Hiện mật khẩu">
                            <i class="tc-login-icon tc-login-icon--eye" role="presentation"/>
                        </button>
                    </div>
                </div>

                <p class="alert alert-danger tc-login-alert" t-if="error" role="alert">
                    <t t-esc="error"/>
                </p>
                <p class="alert alert-success tc-login-alert tc-login-alert--success" t-if="message" role="status">
                    <t t-esc="message"/>
                </p>

                <div class="tc-login-helper">
                    <label class="tc-login-remember" for="remember_me">
                        <input id="remember_me" type="checkbox" name="remember_me"/>
                        <span class="tc-login-remember__box"/>
                        <span>Ghi nhớ đăng nhập</span>
                    </label>
                    <a t-if="has_auth_signup" href="/web/reset_password" class="tc-login-helper__link">Quên mật khẩu?</a>
                </div>

                <div class="oe_login_buttons tc-login-actions">
                    <button type="submit" class="btn btn-primary tc-login-submit">Đăng nhập</button>
                    <t t-if="debug">
                        <button type="submit" name="redirect" value="/web/become" class="btn btn-link btn-sm tc-login-superuser">Đăng nhập bằng superuser</button>
                    </t>
                    <t t-call="web.login_oauth"/>
                </div>

                <input type="hidden" name="type" value="password"/>
                <input type="hidden" name="redirect" t-att-value="redirect"/>
            </form>
        </xpath>
    </template>

    <template id="tc_login_oauth" inherit_id="web.login_oauth" name="TC Login OAuth">
        <xpath expr="//div[hasclass('o_login_auth')]" position="replace">
            <div t-if="auth_btns" class="o_login_auth tc-login-oauth">
                <div class="tc-login-divider">
                    <span>Hoặc tiếp tục với</span>
                </div>
                <div class="tc-login-oauth__grid">
                    <a t-foreach="auth_btns"
                       t-as="p"
                       t-attf-class="tc-login-oauth__item {{ p.get('list_item_class') }}"
                       t-att-href="p.get('auth_link') or '#'">
                        <i t-att-class="p['css_class']" role="presentation"/>
                        <span t-out="p['body']"/>
                    </a>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
